
generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"   // 👈 ይህንን አዲስ መስመር የግድ ይጨምሩ!
}
datasource db {
  provider = "mysql"
}
model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String?
  tasks     Task[]   // የአንድ ተጠቃሚ ብዙ ተግባራት
  createdAt DateTime @default(now())
}

model Task {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  isCompleted Boolean  @default(false)
  userId      Int      // ከUser ጋር የሚያገናኝ
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
