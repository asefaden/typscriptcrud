{
  "compilerOptions": {
    "target": "ES2017",
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "lib": [
      "esnext"
    ],
    "ignoreDeprecations": "6.0",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@prisma-client": [
        "./prisma/generated/client"
      ]
    },
    "plugins": [
      {
        "name": "next"
      }
    ],
    "allowJs": true
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "prisma/generated/client/**/*.ts", // Explicitly include generated client types
    "prisma/generated/client/index.d.ts", // Ensure the main declaration file is picked up
    "next-env.d.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    // Remove Next.js specific build output folders
    "../frontend",
    ".next",
    "out",
    "frontend"
  ]
}
