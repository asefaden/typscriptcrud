{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true, // Keep as true if using ts-node or a separate transpiler for runtime
    "esModuleInterop": true,
    "module": "NodeNext", // Use NodeNext for modern Node.js module resolution
    "moduleResolution": "NodeNext", // Matches the 'module' setting
    "resolveJsonModule": true,
    "isolatedModules": true,
    // Remove 'jsx' as it's typically not used in a Node.js backend
    "incremental": true,
    // Remove Next.js specific plugins
    // 👇 ADD THESE TWO LINES DIRECTLY HERE
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    // If your backend uses .tsx files, uncomment the line below. Otherwise, keep it removed.
    // "**/*.tsx",
    // Remove Next.js specific type declarations
  ],
  "exclude": [
    "node_modules",
    // Remove Next.js specific build output folders
    "../frontend" 
  ]
}
